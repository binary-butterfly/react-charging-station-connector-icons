{
  "compilerOptions": {
    "lib": [
      "es6",
      "dom"
    ],
    "allowJs": true,
    "target": "es2020",
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "rootDir": ".",
    "sourceMap": true,
    "outDir": "dist",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "./src/*",
    "./vite.config.ts",
    "./vitest.shims.d.ts"
  ]
}
